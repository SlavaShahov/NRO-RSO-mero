POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_password
POSTGRES_DSN=postgres://postgres:change_me_password@postgres:5432/rso_events?sslmode=disable
JWT_SECRET=change_me_jwt_secret_min_32_chars_long
JWT_TTL=15m
JWT_REFRESH_TTL=168h

# Email — отправка списков участников после регистрации на мероприятие
# Для Яндекс.Почты: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465
# Для Gmail:        SMTP_HOST=smtp.gmail.com,  SMTP_PORT=587
# Для Mail.ru:      SMTP_HOST=smtp.mail.ru,    SMTP_PORT=465
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_email@yandex.ru
SMTP_PASSWORD=your_app_password
EMAIL_TO=organizer@example.com