{
  "info": {
    "name": "RSO Events API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "eventId", "value": "1" },
    { "key": "qrCode", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/healthz"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"demo@example.com\",\"password\":\"qwerty123\",\"last_name\":\"Иванов\",\"first_name\":\"Иван\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"demo@example.com\",\"password\":\"qwerty123\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"refresh_token\":\"{{refreshToken}}\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/refresh"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"refresh_token\":\"{{refreshToken}}\"}"
        },
        "url": "{{baseUrl}}/api/v1/auth/logout"
      }
    },
    {
      "name": "List Events",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/events"
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/me"
      }
    },
    {
      "name": "Portfolio",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/portfolio"
      }
    },
    {
      "name": "Register To Event",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/events/{{eventId}}/register"
      }
    },
    {
      "name": "Scan Attendance",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"qr_code\":\"{{qrCode}}\"}"
        },
        "url": "{{baseUrl}}/api/v1/attendance/scan"
      }
    }
  ]
}
